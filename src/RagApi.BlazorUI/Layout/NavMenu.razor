@* Argha - 2026-03-03 - #12 - Redesigned navigation: white navbar, SVG icons, pill nav items *@
@* Argha - 2026-03-04 - #17 - Added Workspaces link and active workspace chip *@
@* Argha - 2026-02-21 - Commented: old Bootstrap dark navbar *@
@* <nav class="navbar navbar-expand-lg navbar-dark bg-dark"> *@
@* Argha - 2026-03-20 - #59 - Dark Orbital Theme: vertical 60px icon-only sidebar *@
@* Argha - 2026-03-20 - #59 - Commented: old horizontal Bootstrap navbar HTML block *@
@inject WorkspaceStateService WsState
@implements IDisposable

<nav class="sidebar">

    @* Logo mark — teal square with arrow icon *@
    <div class="sidebar-logo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="7" y1="17" x2="17" y2="7"/>
            <polyline points="7 7 17 7 17 17"/>
        </svg>
    </div>

    @* Navigation icons *@
    <div class="sidebar-nav">
        <NavLink class="sidebar-link" href="/" Match="NavLinkMatch.All" ActiveClass="active" title="Chat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
        </NavLink>
        <NavLink class="sidebar-link" href="/documents" ActiveClass="active" title="Documents">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
        </NavLink>
        <NavLink class="sidebar-link" href="/workspaces" ActiveClass="active" title="Workspaces">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"/>
                <rect x="14" y="3" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/>
                <rect x="14" y="14" width="7" height="7"/>
            </svg>
        </NavLink>
        <NavLink class="sidebar-link" href="/health" ActiveClass="active" title="Health">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
        </NavLink>
    </div>

    @* Footer: workspace status dot + settings *@
    <div class="sidebar-footer">
        @* Argha - 2026-03-20 - #59 - Workspace status dot: teal=active, amber=none selected *@
        @if (WsState.Active != null)
        {
            <div class="sidebar-ws-dot" title="@WsState.Active.Name"></div>
        }
        else if (WsState.IsInitialized)
        {
            <div class="sidebar-ws-dot ws-dot-none" title="No workspace — get started"></div>
        }
        @* Argha - 2026-03-20 - #59 - Settings icon links to workspaces page *@
        <a href="/workspaces" class="sidebar-link" title="Settings">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
        </a>
    </div>
</nav>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            WsState.OnChanged += OnWorkspaceChanged;
            await WsState.InitializeAsync();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        WsState.OnChanged -= OnWorkspaceChanged;
    }

    private void OnWorkspaceChanged() => InvokeAsync(StateHasChanged);
}
