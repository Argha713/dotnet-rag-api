@* Argha - 2026-03-03 - #14 - Documents page redesign: drag-drop zone, card grid, status dots, tag chips *@
@* Argha - 2026-02-21 - Original documents page: upload card + table listing *@
@page "/documents"
@inject DocumentApiService DocumentService

<PageTitle>Documents — RAG Chat</PageTitle>

<div class="page-body-scroll">
<div style="max-width:1100px;margin:0 auto;padding:var(--space-6) var(--space-4);">

    @* ── Page header ── *@
    <div class="section-header">
        <div>
            <h1 class="section-title">Documents</h1>
            <p class="section-subtitle">Upload and manage your knowledge base</p>
        </div>
        <button class="btn-ghost" @onclick="() => LoadDocumentsAsync(null)" title="Refresh list">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
            </svg>
            Refresh
        </button>
    </div>

    @* ── Upload zone ── *@
    <div class="card-modern mb-6" style="margin-bottom:var(--space-6);">
        <div class="upload-zone @(_isDragOver ? "drag-over" : "")"
             @ondragover:preventDefault="true"
             @ondragover="() => _isDragOver = true"
             @ondragleave="() => _isDragOver = false"
             @ondrop:preventDefault="true"
             @ondrop="() => _isDragOver = false">
            <InputFile OnChange="OnFileSelected" accept=".pdf,.docx,.txt,.md" />
            <div class="upload-zone-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                    <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
                    <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
                </svg>
            </div>
            @if (_selectedFile != null)
            {
                <p class="upload-zone-title" style="color:var(--primary);">@_selectedFile.Name</p>
                <p class="upload-zone-sub">@FormatFileSize(_selectedFile.Size) — ready to upload</p>
            }
            else
            {
                <p class="upload-zone-title">Drop files here or click to browse</p>
                <p class="upload-zone-sub">PDF, DOCX, TXT, MD — up to 50 MB</p>
            }
        </div>

        @* Tags + Upload controls *@
        <div style="display:flex;gap:var(--space-3);align-items:flex-end;margin-top:var(--space-4);flex-wrap:wrap;">
            <div style="flex:1;min-width:200px;">
                <label style="font-size:var(--text-xs);font-weight:var(--weight-medium);color:var(--text-secondary);display:block;margin-bottom:var(--space-1);">
                    Tags (comma-separated)
                </label>
                <input type="text" class="input-modern" placeholder="e.g. finance, q3, report"
                       @bind="_tagsInput" @bind:event="oninput" />
            </div>
            <button class="btn-primary-modern" style="height:38px;padding:0 var(--space-5);"
                    @onclick="UploadAsync"
                    disabled="@(_selectedFile == null || _isUploading)">
                @if (_isUploading)
                {
                    <div class="spinner-sm"></div>
                    <span>Uploading…</span>
                }
                else
                {
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
                        <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
                    </svg>
                    <span>Upload</span>
                }
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_uploadMessage))
        {
            <div class="alert-modern @(_uploadSuccess ? "alert-success" : "alert-danger") mt-3" style="margin-top:var(--space-3);">
                @if (_uploadSuccess)
                {
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="flex-shrink:0;">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                }
                else
                {
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="flex-shrink:0;">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                }
                @_uploadMessage
            </div>
        }

        @* Supported formats *@
        @if (_supportedTypes.Count > 0)
        {
            <div style="display:flex;flex-wrap:wrap;gap:var(--space-1);margin-top:var(--space-3);align-items:center;">
                <span style="font-size:var(--text-xs);color:var(--text-muted);margin-right:var(--space-1);">Supported:</span>
                @foreach (var t in _supportedTypes)
                {
                    <span class="tag-chip">@t</span>
                }
            </div>
        }
    </div>

    @* ── Document list header + tag filter ── *@
    <div class="section-header" style="margin-bottom:var(--space-4);">
        <div>
            <h2 class="section-title" style="font-size:var(--text-lg);">
                Uploaded Documents
                <span style="font-size:var(--text-sm);font-weight:var(--weight-normal);color:var(--text-muted);margin-left:var(--space-2);">@_documents.Count total</span>
            </h2>
        </div>
        <div class="filter-bar">
            <input type="text" class="input-modern" style="width:160px;"
                   placeholder="Filter by tag…"
                   @bind="_tagFilter" @bind:event="oninput"
                   @onkeydown="OnFilterKeyDownAsync" />
            <button class="btn-primary-modern" @onclick="ApplyFilterAsync" style="padding:var(--space-2) var(--space-3);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
                </svg>
                Filter
            </button>
            <button class="btn-ghost" @onclick="ClearFilterAsync">
                All
            </button>
        </div>
    </div>

    @* ── Document cards ── *@
    @if (_isLoading)
    {
        <div style="display:flex;justify-content:center;padding:var(--space-12) 0;">
            <div class="spinner-sm spinner-dark" style="width:24px;height:24px;border-width:3px;"></div>
        </div>
    }
    else if (_documents.Count == 0)
    {
        <div class="card-modern">
            <div class="empty-state">
                <div class="empty-state-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                </div>
                <h3>No documents yet</h3>
                <p>Upload a document above to start building your knowledge base.</p>
            </div>
        </div>
    }
    else
    {
        <div class="docs-grid">
            @foreach (var doc in _documents)
            {
                <div class="doc-card">
                    <div class="doc-card-status-bar @doc.Status.ToLower()"></div>
                    <div class="doc-card-body">
                        <div class="doc-card-header">
                            <div class="doc-card-icon">
                                @if (doc.ContentType.Contains("pdf"))
                                {
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                        <polyline points="14 2 14 8 20 8"/>
                                        <line x1="9" y1="15" x2="15" y2="15"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                        <polyline points="14 2 14 8 20 8"/>
                                    </svg>
                                }
                            </div>
                            <span class="doc-card-name" title="@doc.FileName">@doc.FileName</span>
                        </div>

                        <div class="doc-card-meta">
                            <span class="status-badge @GetStatusClass(doc.Status)">@doc.Status</span>
                            <span style="font-size:var(--text-xs);color:var(--text-muted);">@doc.ChunkCount chunk@(doc.ChunkCount == 1 ? "" : "s")</span>
                        </div>

                        @if (doc.Tags.Count > 0)
                        {
                            <div class="doc-card-tags">
                                @foreach (var tag in doc.Tags)
                                {
                                    <span class="tag-chip">@tag</span>
                                }
                            </div>
                        }

                        @if (doc.ErrorMessage != null)
                        {
                            <div style="font-size:var(--text-xs);color:var(--danger-text);background:var(--danger-light);padding:var(--space-2) var(--space-3);border-radius:var(--radius-sm);">
                                @doc.ErrorMessage
                            </div>
                        }
                    </div>

                    <div class="doc-card-footer">
                        <div>
                            <div class="doc-card-date">@doc.UploadedAt.ToString("MMM d, yyyy")</div>
                            @if (doc.UpdatedAt.HasValue)
                            {
                                <div class="doc-card-date">Updated @doc.UpdatedAt.Value.ToString("MMM d")</div>
                            }
                        </div>
                        <button class="btn-icon btn-icon-danger"
                                @onclick="() => DeleteDocumentAsync(doc.Id)"
                                disabled="@_deletingIds.Contains(doc.Id)"
                                title="Delete document">
                            @if (_deletingIds.Contains(doc.Id))
                            {
                                <div class="spinner-sm spinner-dark" style="width:12px;height:12px;border-width:2px;"></div>
                            }
                            else
                            {
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/>
                                    <path d="M10 11v6"/><path d="M14 11v6"/>
                                    <path d="M9 6V4h6v2"/>
                                </svg>
                            }
                        </button>
                    </div>
                </div>
            }
        </div>
    }

</div>
</div>

@code {
    private List<DocumentDto> _documents = new();
    private List<string> _supportedTypes = new();

    private IBrowserFile? _selectedFile;
    private string _tagsInput = string.Empty;
    private string _tagFilter = string.Empty;
    private bool _isDragOver = false;

    private bool _isLoading = true;
    private bool _isUploading = false;
    private string _uploadMessage = string.Empty;
    private bool _uploadSuccess = false;

    private HashSet<Guid> _deletingIds = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadDocumentsAsync(null),
            LoadSupportedTypesAsync());
    }

    private async Task LoadDocumentsAsync(string? tag)
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            _documents = await DocumentService.GetDocumentsAsync(tag);
        }
        catch (Exception ex)
        {
            _uploadMessage = $"Failed to load documents: {ex.Message}";
            _uploadSuccess = false;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadSupportedTypesAsync()
    {
        try { _supportedTypes = await DocumentService.GetSupportedTypesAsync(); }
        catch { /* non-critical */ }
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _uploadMessage = string.Empty;
        _isDragOver = false;
    }

    private async Task UploadAsync()
    {
        if (_selectedFile == null) return;

        _isUploading = true;
        _uploadMessage = string.Empty;

        try
        {
            var tags = _tagsInput
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

            // Argha - 2026-02-21 - Open IBrowserFile stream here; pass to service to keep service testable
            using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            await DocumentService.UploadDocumentAsync(
                stream, _selectedFile.Name,
                string.IsNullOrEmpty(_selectedFile.ContentType) ? "application/octet-stream" : _selectedFile.ContentType,
                tags);

            _uploadSuccess = true;
            _uploadMessage = $"'{_selectedFile.Name}' uploaded successfully.";
            _selectedFile = null;
            _tagsInput = string.Empty;
            await LoadDocumentsAsync(null);
        }
        catch (Exception ex)
        {
            _uploadSuccess = false;
            _uploadMessage = $"Upload failed: {ex.Message}";
        }
        finally
        {
            _isUploading = false;
        }
    }

    private async Task ApplyFilterAsync()
    {
        await LoadDocumentsAsync(string.IsNullOrWhiteSpace(_tagFilter) ? null : _tagFilter.Trim());
    }

    private async Task DeleteDocumentAsync(Guid id)
    {
        _deletingIds.Add(id);
        try
        {
            await DocumentService.DeleteDocumentAsync(id);
            _documents.RemoveAll(d => d.Id == id);
        }
        catch (Exception ex)
        {
            _uploadMessage = $"Delete failed: {ex.Message}";
            _uploadSuccess = false;
        }
        finally
        {
            _deletingIds.Remove(id);
        }
    }

    private async Task OnFilterKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ApplyFilterAsync();
    }

    private async Task ClearFilterAsync()
    {
        _tagFilter = string.Empty;
        await LoadDocumentsAsync(null);
    }

    private static string GetStatusClass(string status) => status switch
    {
        "Completed"  => "status-success",
        "Processing" => "status-warning",
        "Failed"     => "status-danger",
        _            => "status-info"
    };

    private static string FormatFileSize(long bytes) =>
        bytes < 1024      ? $"{bytes} B" :
        bytes < 1_048_576 ? $"{bytes / 1024.0:F1} KB" :
                            $"{bytes / 1_048_576.0:F1} MB";
}
